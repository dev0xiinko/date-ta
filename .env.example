# Copy to .env.local and fill in. Server-side only — never exposed to the browser.
OPENROUTER_API_KEY=sk-or-...

# Optional: any OpenRouter model slug (default: anthropic/claude-sonnet-4.6)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Optional: comma-separated fallback slugs. Primary fails (downtime/rate limit)
# -> OpenRouter retries down the list, bills only the successful run.
# OPENROUTER_FALLBACK_MODELS=openai/gpt-4o,google/gemini-2.0-flash-001

# Optional: used for OpenRouter's ranking headers
# OPENROUTER_SITE_URL=http://localhost:3000

# Optional: precise styled map thumbnails (Mapbox Static Images, free tier).
# Public token — safe to expose; without it, spots fall back to keyless OSM tiles.
# NEXT_PUBLIC_MAPBOX_TOKEN=pk....
